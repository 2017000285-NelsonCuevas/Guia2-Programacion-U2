Algoritmo EJERCICIO5
	Definir letra Como Caracter
	Escribir "CLASIFICACION DE LETRAS POR RANGO"
	Escribir Sin Saltar "Digite una letra: "
	Leer letra
	
	Segun letra Hacer
		"A" O "a":
			Escribir "EXCELENTE"
		"B" O "b"::
				Escribir "BUENO"
			"C" O "c"::
					Escribir "REGULAR"
				"D" O "d":
					Escribir "DEFICIENTE"
				"F" O "f":
					Escribir "REPROBADO"
				De Otro Modo:
					Escribir "Digite una letra valida entre, A, B, C, D Y F"
			Fin Segun
FinAlgoritmo