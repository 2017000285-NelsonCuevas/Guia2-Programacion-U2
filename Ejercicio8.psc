Algoritmo Menu
	Definir opc Como Entero
	Escribir "MENUUUU"
	Escribir "1. = HAMBURGUESA"
	Escribir "2. = PIZZA"
	Escribir "3 = POLLO FRITO"
	Escribir "4 = ENSALADA"
	Escribir "Ingresa un numero para ordenar: "
	Leer opc
	Segun opc Hacer
		1:
			Escribir "HAMBURGUESA"
		2:
			Escribir "PIZZA"
		3:
			Escribir "POLLO FRITO"
		4:
			Escribir "ENSALADA"
		De Otro Modo:
			Escribir "Ingresa un numero adecuado para ordenar"
	Fin Segun
FinAlgoritmo